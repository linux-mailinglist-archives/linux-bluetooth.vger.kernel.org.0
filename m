-	if (mcl->cc == NULL)
-		return -1;
-
-	sock = g_io_channel_unix_get_fd(mcl->cc);
-
-	cmd = g_malloc(sizeof(mcap_rsp) + len);
-	cmd->op = oc;
-	cmd->rc = rc;
-	cmd->mdl = htons(mdl);
-
-	if (data && len > 0)
-		memcpy(cmd->data, data, len);
-
-	sent = mcap_send_data(sock, cmd, sizeof(mcap_rsp) + len);
-	g_free(cmd);
-
-	return sent;
