-static void mcap_del_mdl(gpointer elem, gpointer user_data)
-{
-	struct mcap_mdl *mdl = elem;
-	gboolean notify = *(gboolean *) user_data;
-
-	if (notify)
-		mdl->mcl->cb->mdl_deleted(mdl, mdl->mcl->cb->user_data);
