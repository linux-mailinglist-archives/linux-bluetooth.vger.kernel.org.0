-uint32_t mcap_get_btclock(struct mcap_mcl *mcl)
-{
-	uint32_t btclock;
-	uint16_t accuracy;
-
-	if (!mcl->csp)
-		return MCAP_BTCLOCK_IMMEDIATE;
-
-	if (!read_btclock_retry(mcl, &btclock, &accuracy))
-		btclock = 0xffffffff;
-
-	return btclock;
-}
