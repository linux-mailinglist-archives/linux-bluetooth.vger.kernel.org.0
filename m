-	for (feat = list->val.dataseq; feat; feat = feat->next) {
-		sdp_data_t *data_type, *mdepid, *role_t, *desc_t;
-
-		if (!SDP_IS_SEQ(feat->dtd))
-			continue;
-
-		mdepid = feat->val.dataseq;
-		if (mdepid == NULL)
-			continue;
-
-		data_type = mdepid->next;
-		if (data_type == NULL)
-			continue;
-
-		role_t = data_type->next;
-		if (role_t == NULL)
