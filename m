-    def _padding(self,  buf):
-        pad = array('B')
-        while ( (len(buf) + len(pad)) % 4 ) != 0:
-            pad.append(0)
-        return pad
-
-    def _basicCheck(self,  buf):
-        if len(buf) < 4 or (len(buf) % 4) != 0 or buf[1] != 0:
