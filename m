-uint64_t mcap_get_timestamp(struct mcap_mcl *mcl,
-				struct timespec *given_time)
-{
-	struct timespec now;
-	uint64_t tmstamp;
-
-	if (!mcl->csp)
-		return MCAP_TMSTAMP_DONTSET;
-
-	if (given_time)
-		now = *given_time;
-	else
-		if (clock_gettime(CLK, &now) < 0)
-			return MCAP_TMSTAMP_DONTSET;
-
-	tmstamp = time_us(&now) - time_us(&mcl->csp->base_time)
-		+ mcl->csp->base_tmstamp;
-
-	return tmstamp;
